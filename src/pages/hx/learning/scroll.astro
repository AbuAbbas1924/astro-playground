---
import "@tw";

const pageSize = 10;
const page = 1;

const response = await fetch(
  `https://hn.algolia.com/api/v1/search?tags=front_page&page=${page - 1}&hitsPerPage=${pageSize}`
);
const data = await response.json();
const hits = data.hits ?? [];
const hasMore = page < (data.nbPages ?? page);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="htmx-config" content='{"selfRequestsOnly":false}' />
    <script src="https://unpkg.com/htmx.org"></script>
    <title>Infinite Scroll</title>
  </head>
  <body class="bg-slate-950 text-slate-100">
    <main class="mx-auto flex min-h-screen w-full max-w-3xl flex-col gap-6 px-4 py-10">
      <header class="space-y-2">
        <p class="text-xs uppercase tracking-[0.35em] text-sky-400">HTMX Learning</p>
        <h1 class="text-3xl font-bold">Infinite Scroll</h1>
        <p class="max-w-xl text-sm text-slate-400">
          Scroll down to keep loading the next page. The loader swaps itself with the next batch, then reappears at the
          end.
        </p>
      </header>

      <ul id="content" class="space-y-3">
        {hits.map((hit) => (
          <li class="rounded-2xl border border-slate-800 bg-slate-900/80 p-4 shadow-lg">
            <a
              href={hit.url || "#"}
              target="_blank"
              rel="noreferrer"
              class="block text-base font-medium text-slate-100 hover:text-sky-400"
            >
              {hit.title || "Untitled"}
            </a>
          </li>
        ))}

        {hasMore && (
          <li
            hx-get={`/hx/learning/scroll-more?page=${page + 1}`}
            hx-trigger="revealed"
            hx-swap="outerHTML"
            class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/40 px-4 py-5 text-center text-sm text-slate-400"
          >
            Loading more stories...
          </li>
        )}
      </ul>
    </main>
  </body>
</html>
