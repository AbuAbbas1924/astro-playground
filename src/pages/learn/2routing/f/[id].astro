---
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const [postsRes, usersRes] = await Promise.all([
    fetch("https://jsonplaceholder.typicode.com/posts"),
    fetch("https://jsonplaceholder.typicode.com/users"),
  ]);

  const posts: { id: number; title: string; body: string; userId: number }[] = await postsRes.json();
  const users: { id: number; name: string; email: string }[] = await usersRes.json();

  const userMap = new Map(users.map((u) => [u.id, u]));

  return posts.map((post) => ({
    params: { id: String(post.id) },
    props: { post, author: userMap.get(post.userId)! },
  }));
};

const { post, author } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{post.title}</title>
  </head>
  <body class="bg-zinc-950 mx-auto p-8 max-w-3xl min-h-screen text-zinc-100">
    <a href="/learning/routing/f/1" class="text-zinc-400 hover:text-zinc-200 text-sm transition">← Back to blog</a>

    <article class="mt-6">
      <span class="text-zinc-500 text-sm">Post #{post.id}</span>
      <h1 class="mt-1 font-bold text-3xl capitalize">{post.title}</h1>

      <div class="flex items-center gap-2 mt-3 text-zinc-400 text-sm">
        <span>By {author.name}</span>
        <span>·</span>
        <span>{author.email}</span>
      </div>

      <p class="mt-6 text-zinc-300 leading-relaxed">{post.body}</p>
    </article>

    <nav class="flex gap-4 mt-10">
      {
        post.id > 1 && (
          <a
            href={`/learning/routing/f/${post.id - 1}`}
            class="bg-zinc-800 hover:bg-zinc-700 px-4 py-2 rounded transition"
          >
            ← Post #{post.id - 1}
          </a>
        )
      }
      {
        post.id < 100 && (
          <a
            href={`/learning/routing/f/${post.id + 1}`}
            class="bg-zinc-800 hover:bg-zinc-700 px-4 py-2 rounded transition"
          >
            Post #{post.id + 1} →
          </a>
        )
      }
    </nav>
  </body>
</html>
