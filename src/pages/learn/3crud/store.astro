<script>
  document.addEventListener("alpine:init", () => {
    Alpine.store("cart", {
      items: [],
      add(item) {
        const existing = this.items.find((i) => i.id === item.id);
        if (existing) {
          existing.quantity = (existing.quantity || 1) + 1;
        } else {
          this.items.push({ ...item, quantity: 1 });
        }
      },
      remove(index) {
        this.items.splice(index, 1);
      },
      increase(index) {
        if (this.items[index]) {
          this.items[index].quantity = (this.items[index].quantity || 1) + 1;
        }
      },
      decrease(index) {
        if (this.items[index]) {
          this.items[index].quantity = Math.max(1, (this.items[index].quantity || 1) - 1);
        }
      },
      get total() {
        return this.items.reduce((sum, i) => sum + i.price * (i.quantity || 1), 0);
      },
      get count() {
        return this.items.reduce((sum, i) => sum + (i.quantity || 1), 0);
      },
    });
  });
</script>

<!-- Cart Counter -->
<div class="flex items-center gap-4 mb-8">
  <span x-data x-text="$store.cart.count" class="bg-red-500 px-3 py-1 rounded-full font-bold text-white text-sm"></span>
  <span x-data x-text="`Total: $${$store.cart.total.toFixed(2)}`" class="font-bold text-lg"></span>
</div>

<!-- Products -->
<div x-data class="space-y-4">
  <button
    @click="$store.cart.add({ id: 1, name: 'Product 1', price: 10 })"
    class="bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded text-white">Add Product 1 ($10)</button
  >
  <button
    @click="$store.cart.add({ id: 2, name: 'Product 2', price: 20 })"
    class="bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded text-white">Add Product 2 ($20)</button
  >
</div>

<!-- Cart Items -->
<div x-data class="mt-8">
  <h2 class="mb-4 font-bold text-xl">Cart Items</h2>
  <template x-for="(item, index) in $store.cart.items" :key="index">
    <div class="flex justify-between items-center bg-gray-100 p-4 rounded-lg">
      <div>
        <p class="font-bold" x-text="item.name"></p>
        <p class="text-gray-600 text-sm" x-text="`$${item.price} each`"></p>
      </div>
      <div class="flex items-center gap-2">
        <button @click="$store.cart.decrease(index)" class="bg-red-500 hover:bg-red-600 px-3 py-1 rounded text-white"
          >−</button
        >
        <span class="px-4 font-bold" x-text="item.quantity || 1"></span>
        <button
          @click="$store.cart.increase(index)"
          class="bg-green-500 hover:bg-green-600 px-3 py-1 rounded text-white">+</button
        >
        <button
          @click="$store.cart.remove(index)"
          class="bg-gray-500 hover:bg-gray-600 ml-4 px-3 py-1 rounded text-white">Remove</button
        >
      </div>
    </div>
  </template>
  <p x-show="$store.cart.items.length === 0" class="mt-4 text-gray-500">Cart is empty</p>
</div>
