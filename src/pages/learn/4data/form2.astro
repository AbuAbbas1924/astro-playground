---
import "@tw";
---

<form
  hx-post="/api/contact"
  hx-target="#form-response"
  hx-swap="innerHTML"
  hx-indicator="#submit-spinner"
  class="space-y-4 max-w-lg"
>
  <div>
    <label class="block mb-1 font-medium text-gray-700 text-sm">Name</label>
    <input name="name" type="text" required class="px-3 py-2 border border-gray-300 rounded-lg w-full" />
  </div>
  <div>
    <label class="block mb-1 font-medium text-gray-700 text-sm">Email</label>
    <input name="email" type="email" required class="px-3 py-2 border border-gray-300 rounded-lg w-full" />
  </div>
  <button type="submit" class="flex items-center gap-2 btn-primary">
    Send
    <span
      id="submit-spinner"
      class="inline-block border-2 border-white border-t-transparent rounded-full w-4 h-4 animate-spin htmx-indicator"
    ></span>
  </button>
  <div id="form-response"></div>
</form>
