---
import "@tw";

interface Props {
  title?: string;
  description?: string;
  tags?: string[];
}

const {
  title = "Card demo",
  description = "No description",
  tags = ["astro", "tailwind", "ui"],
} = Astro.props as Props;

const formattedDate = new Date().toLocaleDateString("en-US");
---

<article class="bg-white shadow-md p-6 rounded-xl">
  <h2 class="font-bold text-gray-900 text-2xl">{title}</h2>
  <p class="mt-2 text-gray-600">{description}</p>
  <time class="text-gray-400 text-sm">{formattedDate}</time>

  <div class="flex gap-2 mt-4">
    {tags.map((tag) => (
      <span class="bg-blue-100 px-2 py-1 rounded text-blue-800 text-xs">{tag}</span>
    ))}
  </div>
</article>
