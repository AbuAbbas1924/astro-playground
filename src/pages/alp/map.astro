---
import "@tw";
---

<section
  class="relative text-gray-600 body-font"
  x-data="{ location: null }"
  x-init="location = await (await fetch('https://api.ipbase.com/v1/json/')).json()"
>
  <div class="flex flex-wrap sm:flex-nowrap mx-auto px-5 py-24 container">
    <template x-if="location != null">
      <div
        class="relative flex justify-start items-end bg-gray-300 sm:mr-10 p-10 rounded-lg md:w-1/2 lg:w-2/3 overflow-hidden"
      >
        <iframe
          width="100%"
          height="100%"
          class="absolute inset-0"
          frameborder="0"
          title="map"
          marginheight="0"
          marginwidth="0"
          scrolling="no"
          :src="`https://maps.google.com/maps?width=100%&height=600&hl=en&q=%C4%B0${location.time_zone}&ie=UTF8&t=&z=10&iwloc=B&output=embed`"
          style="filter: grayscale(1) contrast(1.2) opacity(0.4);"></iframe>
        <div class="relative flex flex-wrap bg-white shadow-md py-6 rounded">
          <div class="px-6 lg:w-1/2">
            <h2 class="font-semibold text-gray-900 text-xs tracking-widest title-font">ADDRESS</h2>
            <p class="mt-1" x-text="`${location.city } ${location.region_name}`"></p>
          </div>
          <div class="mt-4 lg:mt-0 px-6 lg:w-1/2">
            <h2 class="font-semibold text-gray-900 text-xs tracking-widest title-font">IP</h2>
            <a class="text-indigo-500 leading-relaxed" x-text="location.ip">example@email.com</a>
            <h2 class="mt-4 font-semibold text-gray-900 text-xs tracking-widest title-font">PHONE</h2>
            <p class="leading-relaxed">123-456-7890</p>
          </div>
        </div>
      </div>
    </template>

    <div class="flex flex-col bg-white mt-8 md:mt-0 md:ml-auto md:py-8 w-full md:w-1/2 lg:w-1/3" x-ignore>
      <h2 class="mb-1 font-medium text-gray-900 text-lg title-font">Feedback</h2>
      <p class="mb-5 text-gray-600 leading-relaxed">Post-ironic portland shabby chic echo park, banjo fashion axe</p>
      <div class="relative mb-4">
        <label for="name" class="text-gray-600 text-sm leading-7">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          class="bg-white px-3 py-1 border border-gray-300 focus:border-indigo-500 rounded outline-none focus:ring-2 focus:ring-indigo-200 w-full text-gray-700 text-base leading-8 transition-colors duration-200 ease-in-out"
        />
      </div>
      <div class="relative mb-4">
        <label for="email" class="text-gray-600 text-sm leading-7">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="bg-white px-3 py-1 border border-gray-300 focus:border-indigo-500 rounded outline-none focus:ring-2 focus:ring-indigo-200 w-full text-gray-700 text-base leading-8 transition-colors duration-200 ease-in-out"
        />
      </div>
      <div class="relative mb-4">
        <label for="message" class="text-gray-600 text-sm leading-7">Message</label>
        <textarea
          id="message"
          name="message"
          class="bg-white px-3 py-1 border border-gray-300 focus:border-indigo-500 rounded outline-none focus:ring-2 focus:ring-indigo-200 w-full h-32 text-gray-700 text-base leading-6 transition-colors duration-200 ease-in-out resize-none"
        ></textarea>
      </div>
      <button class="bg-indigo-500 hover:bg-indigo-600 px-6 py-2 border-0 rounded focus:outline-none text-white text-lg"
        >Button</button
      >
      <p class="mt-3 text-gray-500 text-xs">
        Chicharrones blog helvetica normcore iceland tousled brook viral artisan.
      </p>
    </div>
  </div>
</section>
