---
import Author from "./Author.astro";
const { data } = Astro.props;
---

<article>
  <img src={data.hero} alt={data.title} />
  <div>
    <p>{data.category}</p>
    <p>{data.title}</p>
    <p>{data.description}</p>
    <Author name={data.author.name} avatar={data.author.avatar} time={data.time} />
  </div>
</article>
