---
// src/pages/blog/[id].astro
//
// ⚠️ Astro 5 changes:
//   - Dynamic param is `id` (not `slug`) — auto-generated from filename
//   - render() is imported from 'astro:content' (not a method on the entry)

export const prerender = true;
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id }, // ⚠️ `id` not `slug` in Astro 5
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post); // ⚠️ standalone function, not post.render()
---

<BaseLayout title={post.data.title}>
  <Content />
</BaseLayout>
