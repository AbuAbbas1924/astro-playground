export async function getStaticPaths() {
  const res = await fetch("https://jsonplaceholder.typicode.com/users");
  const users = await res.json();

  return users.map((user) => ({
    params: { id: String(user.id) },
    props: { user },
  }));
}

const { user } = Astro.props;
---

<html>
  <body>
    <h1>{user.name}</h1>
    <p>{user.email}</p>
    <span>{user.id}€</span>
  </body>
</html>
