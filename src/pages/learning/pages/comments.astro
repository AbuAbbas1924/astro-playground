---
import BaseLayout from "../../../layouts/learning/BaseLayout.astro";
import { db } from "../../../db/index";
import { comments } from "../../../db/schema";

const rows = db.select().from(comments).all();
---

<BaseLayout title="Comments">
  <div class="mx-auto max-w-xl space-y-6">
    <h1 class="font-bold text-2xl">Comments</h1>

    <!-- Add comment form -->
    <form
      hx-post="/learning/api/comments"
      hx-target="#comment-list"
      hx-swap="beforeend"
      hx-on::after-request="this.reset()"
      class="space-y-3 bg-gray-50 border border-gray-200 rounded-lg p-4"
    >
      <input
        name="author"
        placeholder="Your name"
        required
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500"
      />
      <textarea
        name="body"
        placeholder="Write a comment..."
        required
        rows="3"
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500"
      ></textarea>
      <button
        type="submit"
        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md"
      >Post</button>
    </form>

    <!-- Comment list (server-rendered initially) -->
    <ul id="comment-list" class="space-y-3">
      {rows.length === 0
        ? <li class="text-gray-400 text-center py-4">No comments yet.</li>
        : rows.map(c => (
            <li id={`comment-${c.id}`} class="flex justify-between items-start bg-white border border-gray-200 rounded-lg p-4">
              <div>
                <span class="font-semibold text-gray-800">{c.author}</span>
                <p class="text-gray-600 mt-1">{c.body}</p>
              </div>
              <button
                hx-delete={`/learning/api/comments/${c.id}`}
                hx-target={`#comment-${c.id}`}
                hx-swap="outerHTML"
                class="text-red-400 hover:text-red-600 text-sm ml-4 shrink-0"
              >Delete</button>
            </li>
          ))
      }
    </ul>
  </div>
</BaseLayout>
