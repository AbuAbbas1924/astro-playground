---
import "@tw";
const items = ["Apple", "Banana", "Cherry"];
const isLoggedIn = true;
---

{isLoggedIn ? <p class="text-green-600">Welcome!</p> : <p class="text-gray-500">Please log in.</p>}

<ul class="space-y-2">
  {
    items.map((item, i) => (
      <li class="flex items-center gap-2">
        <span class="text-gray-400">{i + 1}.</span>
        <span>{item}</span>
      </li>
    ))
  }
</ul>

<!-- ⚠️ set:html — Only use with TRUSTED content (XSS risk!) -->
<div set:html="<strong>Bold</strong>" />
