---
import "@tw";

const pageSize = 10;
const currentPage = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1"));

const allPosts = Array.from({ length: 50 }, (_, i) => ({
  title: `Post ${i + 1}`,
}));

const lastPage = Math.ceil(allPosts.length / pageSize);
const start = (currentPage - 1) * pageSize;
const page = {
  data: allPosts.slice(start, start + pageSize),
  currentPage,
  lastPage,
  url: {
    prev: currentPage > 1 ? `/learning/pages/pagination?page=${currentPage - 1}` : null,
    next: currentPage < lastPage ? `/learning/pages/pagination?page=${currentPage + 1}` : null,
  },
};
---

<ul class="space-y-2">
  {page.data.map((post) => <li class="rounded-lg bg-white p-3 shadow">{post.title}</li>)}
</ul>

<nav class="mt-8 flex gap-4">
  {page.url.prev && <a href={page.url.prev}>← Previous</a>}
  <span>Page {page.currentPage} of {page.lastPage}</span>
  {page.url.next && <a href={page.url.next}>Next →</a>}
</nav>
