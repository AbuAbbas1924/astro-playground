---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import "@tw";
---

<BaseLayout title="Search">
  <div class="mx-auto max-w-xl">
    <input
      type="search"
      name="q"
      placeholder="Search posts..."
      hx-get="/learning/api/search"
      hx-trigger="keyup changed delay:300ms"
      hx-target="#search-results"
      hx-indicator="#search-spinner"
      class="px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 w-full"
    />

    <div id="search-spinner" class="mt-4 text-center htmx-indicator">
      <div class="inline-block border-2 border-blue-600 border-t-transparent rounded-full w-6 h-6 animate-spin"></div>
    </div>

    <div id="search-results" class="space-y-3 mt-4"></div>
  </div>
</BaseLayout>
