---
import Card2 from "../components/Card2.astro";
import "@tw";
import Modal from "../components/Modal.astro";
import ClassList from "../components/ClassList.astro";
---

<Card2 title="t1" href="https://google.com" featured />
<Card2 title="t2" href="https://google.com" />
<Card2 title="t3" href="https://google.com" featured />

<Modal title="Confirm">
  <p>Are you sure?</p>
  <div slot="footer" class="flex gap-2">
    <button class="bg-red-600 px-4 py-2 rounded text-white">Delete</button>
    <button class="bg-gray-200 px-4 py-2 rounded" @click="show=false">Cancel</button>
  </div>
</Modal>
<hr class="my-4 border-4 border-black" />
<ClassList variant="primary">primary</ClassList>
<ClassList variant="secondary" size="lg">secondary lg</ClassList>
