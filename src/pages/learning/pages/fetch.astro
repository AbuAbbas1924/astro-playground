---
// All fetch() in frontmatter runs on SERVER — never shipped to browser
const response = await fetch("https://jsonplaceholder.typicode.com/posts?_limit=5");
const post_limit = await response.json();

// Parallel fetches
// const [usersRes, commentsRes] = await Promise.all([
//   fetch('https://jsonplaceholder.typicode.com/users?_limit=5'),
//   fetch('https://jsonplaceholder.typicode.com/comments?_limit=5')
// ]);
// const [users, comments] = await Promise.all([usersRes.json(), commentsRes.json()]);

// const users = await (await fetch('https://jsonplaceholder.typicode.com/users?_limit=5')).json();
const [usersRes, postsRes] = await Promise.all([
  fetch("https://jsonplaceholder.typicode.com/users"),
  fetch("https://jsonplaceholder.typicode.com/posts"),
]);
const users = await usersRes.json();
const posts = await postsRes.json();
---

<h1 class="mb-6 font-bold text-3xl">Fetch API Example</h1>
<h2 class="mb-4 font-semibold text-2xl">Posts (limited to 5)</h2>
<ul class="mb-8 list-disc list-inside">
  {
    post_limit.map((post) => (
      <li key={post.id} class="mb-2">
        <strong>{post.title}</strong>
        <p>{post.body}</p>
      </li>
    ))
  }
</ul>

<h2 class="mb-4 font-semibold text-2xl">Users</h2>
<ul class="mb-8 list-disc list-inside">
  {
    users.map((user) => (
      <li key={user.id} class="mb-2">
        <strong>{user.name}</strong> ({user.email})
      </li>
    ))
  }
</ul>

<h2 class="mb-4 font-semibold text-2xl">Posts (all)</h2>
<ul class="list-disc list-inside">
  {
    posts.slice(0, 10).map((post) => (
      <li key={post.id} class="mb-2">
        <strong>{post.title}</strong>
        <p>{post.body}</p>
      </li>
    ))
  }
</ul>
