---
import "@tw";
---

<div x-data="{ count: 0 }" class="inline-flex items-center gap-4 bg-white shadow-xs p-4 rounded-xl">
  <button
    @click="count--"
    :disabled="count <= 0"
    class="flex justify-center items-center bg-red-100 hover:bg-red-200 disabled:opacity-50 rounded-full w-10 h-10 font-bold text-red-600 text-lg"
    >-</button
  >
  <span x-text="count" class="w-12 font-mono font-bold text-2xl text-center"></span>
  <button
    @click="count++"
    class="flex justify-center items-center bg-green-100 hover:bg-green-200 rounded-full w-10 h-10 font-bold text-green-600 text-lg"
    >+</button
  >
</div>
