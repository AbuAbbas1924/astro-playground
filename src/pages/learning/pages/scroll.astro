---
import "@tw";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Scroll">
  <div class="space-y-8">
    <p>
      This page demonstrates how to use htmx to load more content as the user scrolls down. Scroll to the bottom to see
      it in action!
    </p>
    <div id="content" class="space-y-4">
      {Array.from({ length: 5 }, (_, i) => <div class="bg-gray-100 p-4 rounded-lg">Item {i + 1}</div>)}
      <div
        hx-get="/learning/api/feed?page=1"
        hx-trigger="revealed"
        hx-swap="outerHTML"
        class="py-4 text-gray-500 text-center"
      >
        Loading more...
      </div>
    </div>
  </div>
</BaseLayout>
