---
// src/pages/index.astro
export const prerender = false;
import "@tw";
---

<html>
  <head>
    <script src="https://unpkg.com/alpinejs" defer></script>
  </head>

  <body class="p-5 font-sans">
    <div x-data="chat()">
      <h2 class="mb-3 font-semibold text-xl">Simple Chat</h2>

      <div class="flex items-center gap-2 mb-3">
        <span class="inline-block rounded-full w-2.5 h-2.5" :class="connected ? 'bg-green-500' : 'bg-red-500'"></span>
        <span x-text="connected ? 'Connected' : 'Disconnected'" class="text-gray-500 text-sm"></span>
      </div>

      <div class="space-y-1 mb-3 p-2 border border-gray-300 rounded h-48 overflow-auto">
        <template x-for="m in msgs">
          <div x-text="m" class="text-sm"></div>
        </template>
      </div>

      <div class="flex gap-2">
        <input
          x-model="input"
          @keydown.enter="send()"
          placeholder="message..."
          class="flex-1 px-3 py-1.5 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400 text-sm"
        />
        <button
          @click="send()"
          class="bg-blue-500 hover:bg-blue-600 px-4 py-1.5 rounded text-white text-sm transition-colors">Send</button
        >
      </div>
    </div>

    <script is:inline>
      function chat() {
        return {
          ws: null,
          msgs: [],
          input: "",
          connected: false,

          init() {
            this.ws = new WebSocket(`ws://${location.host}/api/chat/b1/ws`);

            this.ws.onopen = () => {
              this.connected = true;
            };
            this.ws.onclose = () => {
              this.connected = false;
            };
            this.ws.onerror = () => {
              this.connected = false;
            };

            this.ws.onmessage = (e) => {
              this.msgs.push(e.data);
              console.log("Received message:", e.data);
            };
          },

          send() {
            if (!this.input) return;
            this.ws.send(this.input);
            this.input = "";
          },
        };
      }
    </script>
  </body>
</html>
