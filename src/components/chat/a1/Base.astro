---
interface Props {
  title?: string;
}

import "@tw";

const { title = "ChatApp" } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-gray-950 h-full text-gray-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="flex justify-center items-center p-4 h-full">
    <slot />
  </body>
</html>
