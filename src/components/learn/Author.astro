---
interface Props {
  name: string;
  avatar: string;
  time: string;
}

const { name, avatar, time } = Astro.props as Props;
---

<div class="mt-4 flex items-center gap-3">
  <img src={avatar} alt={name} class="h-10 w-10 rounded-full object-cover" />
  <div>
    <p class="text-sm font-medium text-slate-900">{name}</p>
    <p class="text-xs text-slate-500">{time}</p>
  </div>
</div>
