---
import { string } from "astro:schema";

interface Props {
  title: string;
  href: string;
  image?: string;
  featured?: boolean;
}

const { title, href, image, featured = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    "block p-4 rounded-lg transition-all duration-200",
    "hover:shadow-lg hover:-translate-y-1",
    { "border-2 border-yellow-400 bg-yellow-50": featured },
    { "border border-gray-200 bg-white": !featured },
  ]}
>
  {image && <img src={image} alt="" class="rounded-md w-full h-48 object-cover" />}
  <h3 class="mt-3 font-semibold text-gray-900 text-lg">{title}</h3>
</a>
